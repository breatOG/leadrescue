# ─── Database ─────────────────────────────────────────────────────────────────
# Railway sets DATABASE_URL automatically. For local dev, point at your Postgres.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/leadrescue?schema=public"
# On Railway, also set this so the server uses the public URL on startup:
DATABASE_PUBLIC_URL=""

# ─── Server ───────────────────────────────────────────────────────────────────
# The publicly accessible URL of this server (used for Twilio webhooks, Stripe redirects, emails).
# On Railway: copy the generated domain, e.g. https://leadrescue-production.up.railway.app
APP_BASE_URL="https://your-railway-domain.up.railway.app"

# The frontend origin for CORS (same as APP_BASE_URL when client is served from the same process).
CLIENT_URL="https://your-railway-domain.up.railway.app"

NODE_ENV="production"
PORT=4000

# Generate a strong random secret: openssl rand -hex 64
JWT_SECRET="replace-with-64-char-random-hex"

# ─── Twilio ───────────────────────────────────────────────────────────────────
# Required for SMS and voice. Find these in your Twilio console.
TWILIO_ACCOUNT_SID="ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
TWILIO_AUTH_TOKEN="your_twilio_auth_token"

# Optional: API Key credentials (alternative to auth token)
TWILIO_API_KEY_SID=""
TWILIO_API_KEY_SECRET=""

# The Twilio phone number assigned to the seed/demo business (E.164 format).
# Leave blank if you want users to provision their own numbers in-app.
TWILIO_PHONE_NUMBER=""

# ─── Stripe ───────────────────────────────────────────────────────────────────
# Required for subscriptions. Find in Stripe Dashboard → Developers → API keys.
STRIPE_SECRET_KEY="sk_live_YOUR_KEY_HERE"

# Webhook signing secret from Stripe Dashboard → Developers → Webhooks → your endpoint.
# Required to verify Stripe events (renewal reminders, plan changes, etc.)
STRIPE_WEBHOOK_SECRET="whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# Price IDs for each plan. Create recurring monthly prices in Stripe Product Catalog,
# then paste the price_xxx IDs here.
STRIPE_PRICE_STARTER="price_xxxxxxxxxxxxxxxxxxxx"
STRIPE_PRICE_PRO="price_xxxxxxxxxxxxxxxxxxxx"
STRIPE_PRICE_SCALE="price_xxxxxxxxxxxxxxxxxxxx"

# ─── OpenAI ───────────────────────────────────────────────────────────────────
# Required for AI lead qualification and voice. Leave blank to use mock mode locally.
OPENAI_API_KEY="sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# Voice AI settings (only used if ENABLE_AI_VOICE=true and OpenAI Realtime API is available)
OPENAI_REALTIME_MODEL="gpt-4o-realtime-preview"
OPENAI_REALTIME_VOICE="alloy"
ENABLE_AI_VOICE=false
ENABLE_VOICE_MEMORY=false

# ─── Email ────────────────────────────────────────────────────────────────────
# Option A: Resend (recommended) — sign up at resend.com, verify your domain, get an API key.
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx"
RESEND_FROM="LeadRescue <hello@yourdomain.com>"

# Option B: SMTP (e.g. Gmail, SendGrid, Mailgun) — used if SMTP_HOST is set.
# Gmail: enable 2FA, create an App Password at myaccount.google.com/apppasswords
SMTP_HOST=""
SMTP_PORT=465
SMTP_USER=""
SMTP_PASS=""
EMAIL_FROM=""

# ─── Timezone ─────────────────────────────────────────────────────────────────
# IANA timezone for appointment slot display in the AI voice agent.
# See: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
BUSINESS_TIMEZONE="America/Chicago"
