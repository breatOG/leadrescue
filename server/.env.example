DATABASE_URL="postgresql://user:password@host:5432/leadrescue?schema=public"
JWT_SECRET="change-me"
PORT=4000
APP_BASE_URL="https://your-app.up.railway.app"
CLIENT_URL="http://localhost:5173"

# --- Email ---
# Option 1 (works for ALL recipients, no domain needed): Gmail SMTP.
# SMTP_PASS must be a Gmail App Password: https://myaccount.google.com/apppasswords
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=465
SMTP_USER="you@gmail.com"
SMTP_PASS=""
EMAIL_FROM="LeadRescue <you@gmail.com>"

# Option 2: Resend (needs a verified domain at resend.com/domains to reach arbitrary recipients).
RESEND_API_KEY=""
# RESEND_FROM="LeadRescue <noreply@yourdomain.com>"

OPENAI_API_KEY=""
OPENAI_REALTIME_MODEL="gpt-4o-realtime-preview"
OPENAI_REALTIME_VOICE="alloy"
ENABLE_AI_VOICE=true
ENABLE_VOICE_MEMORY=false

TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_API_KEY_SID=""
TWILIO_API_KEY_SECRET=""
TWILIO_PHONE_NUMBER=""
