generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum LeadStatus {
  new
  texting
  qualified
  appointment_booked
  closed
  spam
}

enum LeadPriority {
  emergency
  high
  normal
  low
}

enum MessageDirection {
  inbound
  outbound
}

enum MessageChannel {
  sms
  voice
  internal
}

enum AppointmentStatus {
  booked
  cancelled
  completed
}

model User {
  id                   String      @id @default(cuid())
  email                String      @unique
  phoneNumber          String?     @unique
  passwordHash         String
  name                 String?
  role                 String      @default("owner")
  emailVerified        Boolean     @default(false)
  stripeCustomerId     String?
  stripeSubscriptionId String?
  subscriptionStatus   String      @default("inactive")
  subscriptionPlan     String?
  staffBusinessId      String?
  staffBusiness        Business?   @relation("staffMembers", fields: [staffBusinessId], references: [id])
  permissions          String[]    @default([])
  business             Business?
  authTokens           AuthToken[]
  createdAt            DateTime    @default(now())
  updatedAt            DateTime    @updatedAt
}

enum AuthTokenType {
  email_verify
  password_reset
}

model AuthToken {
  id        String        @id @default(cuid())
  userId    String
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      AuthTokenType
  tokenHash String        @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime      @default(now())

  @@index([userId, type])
}

model SubscriptionPlan {
  id          String     @id @default(cuid())
  name        String     @unique
  priceCents  Int
  description String
  businesses  Business[]
}

model Business {
  id                     String                 @id @default(cuid())
  ownerId                String                 @unique
  owner                  User                   @relation(fields: [ownerId], references: [id])
  staffMembers           User[]                 @relation("staffMembers")
  invitations            Invitation[]
  subscriptionPlanId     String?
  subscriptionPlan       SubscriptionPlan?      @relation(fields: [subscriptionPlanId], references: [id])
  name                   String
  industryType           String
  twilioPhoneNumber      String?
  businessPhoneNumber    String?
  ownerNotificationPhone String?
  ownerNotificationEmail String?
  serviceAreas           String[]               @default([])
  businessHours          Json?
  callHandlingMode       String                 @default("ring_first")
  ringSeconds            Int                    @default(15)
  afterHoursRing         Boolean                @default(false)
  ringNumbers            String[]               @default([])
  smsStatus              String                 @default("not_started")
  twilioMsgServiceSid    String?
  twilioBrandSid         String?
  twilioCampaignSid      String?
  smsFormData            Json?
  createdAt              DateTime               @default(now())
  updatedAt              DateTime               @updatedAt
  leads                  Lead[]
  appointments           Appointment[]
  availability           BusinessAvailability[]
  serviceTypes           ServiceType[]
  webhookLogs            WebhookLog[]
}

model ServiceType {
  id         String   @id @default(cuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  name       String
  createdAt  DateTime @default(now())

  @@unique([businessId, name])
}

model BusinessAvailability {
  id         String   @id @default(cuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  dayOfWeek  Int
  startTime  String
  endTime    String
  slotMinutes Int     @default(60)
  createdAt  DateTime @default(now())
}

model Lead {
  id                       String          @id @default(cuid())
  businessId               String
  business                 Business        @relation(fields: [businessId], references: [id], onDelete: Cascade)
  customerName             String?
  customerPhone            String
  address                  String?
  zipCode                  String?
  jobType                  String?
  urgency                  String?
  issueDescription         String?
  preferredAppointmentTime String?
  photosAvailable          Boolean?
  source                   String          @default("sms")
  status                   LeadStatus      @default(new)
  priority                 LeadPriority    @default(normal)
  handoffMode              String          @default("ai")
  aiSummary                String?
  manualNotes              String?
  lastMessage              String?
  createdAt                DateTime        @default(now())
  updatedAt                DateTime        @updatedAt
  messages                 Message[]
  appointments             Appointment[]

  @@index([businessId, customerPhone])
}

model Message {
  id          String           @id @default(cuid())
  leadId      String
  lead        Lead             @relation(fields: [leadId], references: [id], onDelete: Cascade)
  direction   MessageDirection
  channel     MessageChannel   @default(sms)
  body        String
  twilioSid   String?
  createdAt   DateTime         @default(now())
}

model Appointment {
  id           String            @id @default(cuid())
  businessId   String
  business     Business          @relation(fields: [businessId], references: [id], onDelete: Cascade)
  leadId       String
  lead         Lead              @relation(fields: [leadId], references: [id], onDelete: Cascade)
  startAt      DateTime
  endAt        DateTime
  status       AppointmentStatus @default(booked)
  calendarEventId String?
  notes        String?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  @@index([businessId, startAt])
}

model Invitation {
  id          String    @id @default(cuid())
  businessId  String
  business    Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  email       String
  name        String?
  tokenHash   String    @unique
  expiresAt   DateTime
  acceptedAt  DateTime?
  createdAt   DateTime  @default(now())

  @@index([businessId])
}

model WebhookLog {
  id         String   @id @default(cuid())
  businessId String?
  business   Business? @relation(fields: [businessId], references: [id], onDelete: SetNull)
  provider   String
  eventType  String
  payload    Json
  createdAt  DateTime @default(now())
}
